---
interface Props { title: string }
const { title } = Astro.props
const base = Astro.url.pathname === '/' ? '' : '/'
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Vai Pizza</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href={`${base}#home`} class="nav-logo" aria-label="Vai Pizza">
        <img src="/images/vai-pizza-logo.png" alt="Vai Pizza" />
      </a>
      <div class="nav-links">
        <a href={`${base}#rodizio`}>Rodizio</a>
        <a href={`${base}#preise`}>All you can eat</a>
        <a href="/karte">Karte</a>
        <a href={`${base}#bar`}>Bar & Cocktails</a>
        <a href={`${base}#besuch`}>Besuch</a>
      </div>
    </div>
  </nav>

  <main class="legal-content">
    <div class="container">
      <h1>{title}</h1>
      <slot />
    </div>
  </main>

  <footer class="footer" style="padding: 40px 0;">
    <div class="container" style="text-align:center;font-size:13px;color:rgba(245,236,214,.35);">
      © 2026 Vai Pizza · Neustadtring 30A, 38114 Braunschweig
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
  .legal-content {
    max-width: 760px;
    margin: 0 auto;
    padding: 64px 32px 100px;
  }
  .legal-content h1 {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 48px;
    font-weight: 400;
    margin: 0 0 48px;
    color: var(--green-800);
  }
  .legal-content h2 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 400;
    margin: 40px 0 12px;
    color: var(--green-800);
  }
  .legal-content p { font-size: 15px; line-height: 1.75; margin: 0 0 16px; color: rgba(26,26,22,.8); }
  .legal-content a { color: var(--tomato); text-decoration: underline; }
</style>
