---
// Self-hosted fonts (SIL OFL-1.1) — als ESM importiert, damit Vite die
// woff/woff2-Dateien in den Build kopiert. Kein externer Google-Fonts-Request.
import '@fontsource/caveat/latin-400.css'
import '@fontsource/caveat/latin-700.css'
import '@fontsource/dm-serif-display/latin-400.css'
import '@fontsource/dm-serif-display/latin-400-italic.css'
import '@fontsource/manrope/latin-400.css'
import '@fontsource/manrope/latin-600.css'
import '@fontsource/manrope/latin-700.css'
import '@fontsource/manrope/latin-800.css'
import '../styles/global.css'
import { Image } from 'astro:assets'
import logo from '../assets/images/vai-pizza-logo.png'

interface Props { title: string }
const { title } = Astro.props
const base = Astro.url.pathname === '/' ? '' : '/'
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Vai Pizza</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href={`${base}#home`} class="nav-logo" aria-label="Vai Pizza">
        <Image src={logo} alt="Vai Pizza" width={99} height={56} densities={[1, 2]} format="webp" quality={60} loading="eager" />
      </a>
      <div class="nav-links">
        <a href={`${base}#rodizio`}>Rodizio</a>
        <a href={`${base}#preise`}>All you can eat</a>
        <a href="/karte">Karte</a>
        <a href={`${base}#bar`}>Bar & Cocktails</a>
        <a href={`${base}#besuch`}>Besuch</a>
      </div>
      <button class="nav-toggle" aria-label="Menü öffnen" aria-expanded="false" aria-controls="navMobile">
        <span></span><span></span><span></span>
      </button>
    </div>

    <div class="nav-mobile" id="navMobile">
      <a href={`${base}#rodizio`}>Rodizio</a>
      <a href={`${base}#preise`}>All you can eat</a>
      <a href="/karte">Karte</a>
      <a href={`${base}#bar`}>Bar & Cocktails</a>
      <a href={`${base}#besuch`}>Besuch</a>
      <a href={`${base}#besuch`} class="btn btn-primary nav-mobile-cta">Tisch reservieren</a>
    </div>
  </nav>

  <script>
    const toggle = document.querySelector('.nav-toggle')
    const menu = document.getElementById('navMobile')
    if (toggle && menu) {
      const setOpen = (open: boolean) => {
        menu.classList.toggle('open', open)
        toggle.classList.toggle('is-open', open)
        toggle.setAttribute('aria-expanded', String(open))
        toggle.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen')
        document.body.classList.toggle('nav-open', open)
      }
      toggle.addEventListener('click', () => setOpen(!menu.classList.contains('open')))
      menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => setOpen(false)))
    }
  </script>

  <main class="legal-content">
    <div class="container">
      <h1>{title}</h1>
      <slot />
    </div>
  </main>

  <footer class="footer" style="padding: 40px 0;">
    <div class="container" style="text-align:center;font-size:13px;color:rgba(245,236,214,.35);">
      © 2026 Vai Pizza · Neustadtring 30A, 38114 Braunschweig
    </div>
  </footer>
</body>
</html>

<style is:global>
  .legal-content {
    max-width: 760px;
    margin: 0 auto;
    padding: 64px 32px 100px;
  }
  .legal-content h1 {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 48px;
    font-weight: 400;
    margin: 0 0 48px;
    color: var(--green-800);
  }
  .legal-content h2 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 400;
    margin: 40px 0 12px;
    color: var(--green-800);
  }
  .legal-content p { font-size: 15px; line-height: 1.75; margin: 0 0 16px; color: rgba(26,26,22,.8); }
  .legal-content a { color: var(--tomato); text-decoration: underline; }
</style>
