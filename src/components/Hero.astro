---
---
<header id="home" class="hero">
  <div class="hero-inner">
    <div>
      <span class="hero-script">Original Brazilian Spirit</span>
      <h1>
        Pizza<br/>
        <span class="accent">Rodizio</span><br/>
        <span class="stroke">All-you-eat</span>
      </h1>
      <p class="hero-sub">
        Brasilianische Gastfreundschaft, italienische Pizza und ein Glas Caipirinha in der Hand.
        Setz dich an unseren Tisch — wir bringen frische Pizzen, so lange du Lust hast.
      </p>
      <div class="hero-ctas">
        <a href="#preise" class="btn btn-primary">
          Preise ansehen
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
        </a>
        <a href="#rodizio" class="btn btn-ghost-light">Was ist Rodizio?</a>
      </div>
      <div class="hero-meta">
        <div><strong>Mo–So</strong>ab 17:00 Uhr geöffnet</div>
        <div><strong>2 Etagen</strong>+ Außenbereich für Sommerabende</div>
        <div><strong>14,50&nbsp;€</strong>Pizza ohne Limit, ohne Verstecken</div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-pizza-glow"></div>
      <div class="hero-pizza-ring"></div>
      <div class="hero-pizza-disc"></div>
      <div class="hero-pizza-disc inner"></div>
      <img class="hero-pizza-img" src="/images/vai-pizza-pizza.png" alt="Pizza" />

      <div class="hero-tags tl">
        <div class="hero-tag"><span class="dot"></span>Hand­geknetet</div>
        <div class="hero-tag yellow"><span class="dot"></span>24h Teig­führung</div>
      </div>
      <div class="hero-tags br">
        <div class="hero-tag dark"><span class="dot"></span>Über 20 Sorten</div>
        <div class="hero-tag"><span class="dot"></span>Steinofen</div>
      </div>
    </div>
  </div>

  <div class="hero-marquee">
    <div class="marquee-track">
      <span>Pizza Rodizio</span>
      <span>So viel du magst</span>
      <span>Cocktails</span>
      <span>Brasilianisch · Italienisch</span>
      <span>Seit 2014</span>
      <span>Braunschweig</span>
      <span>Pizza Rodizio</span>
      <span>So viel du magst</span>
      <span>Cocktails</span>
      <span>Brasilianisch · Italienisch</span>
      <span>Seit 2014</span>
      <span>Braunschweig</span>
    </div>
  </div>
</header>
