---
const reviews = [
  {
    name: "Jasmin K.", initial: "J", color: "#a8c93b", stars: 5,
    time: "vor 2 Wochen", badge: "Local Guide",
    body: "Endlich mal All-you-can-eat ohne Abstriche bei der Qualität. Die Pizza kam frisch und richtig heiß an den Tisch, das Personal war super aufmerksam. Werden definitiv wiederkommen!",
  },
  {
    name: "Markus B.", initial: "M", color: "#f0cf2e", stars: 5,
    time: "vor 1 Monat", badge: null,
    body: "Ich bin schon seit Jahren Stammgast. Die Caipirinha hier ist die beste in Braunschweig, kein Witz. Und das Rodizio-Konzept funktioniert einfach — man muss nichts entscheiden, das Essen kommt zu einem.",
  },
  {
    name: "Lena S.", initial: "L", color: "#c54a2c", stars: 4,
    time: "vor 3 Wochen", badge: null,
    body: "Schöner Außenbereich, an warmen Abenden perfekt. Pizza war lecker, einmal mussten wir etwas länger auf die nächste Runde warten. Aber Preis-Leistung absolut top.",
  },
  {
    name: "David O.", initial: "D", color: "#a8c93b", stars: 5,
    time: "vor 5 Tagen", badge: null,
    body: "Waren mit 8 Leuten zum Geburtstag da. Würfle-deinen-Cocktail-Aktion war ein Knaller! Stimmung war super, Personal entspannt.",
  },
  {
    name: "Sophie R.", initial: "S", color: "#f0cf2e", stars: 5,
    time: "vor 2 Monaten", badge: "Local Guide",
    body: "Familienabend mit den Kindern — alle satt geworden und alle glücklich. Faire Preise und keine versteckten Aufschläge.",
  },
  {
    name: "Tobias H.", initial: "T", color: "#c54a2c", stars: 5,
    time: "vor 1 Woche", badge: null,
    body: "Die brasilianische Note macht den Laden besonders. Caipi-Auswahl ist riesig, und die Pizza Rustica ist mein Favorit. Zwei Etagen, immer einen Platz zu finden.",
  },
]
---
<section id="bewertungen" class="reviews">
  <div class="container">
    <div class="reviews-head">
      <div>
        <span class="eyebrow dark">Was unsere Gäste sagen</span>
        <h2 class="display italic">Echte Stimmen, echte Abende.</h2>
      </div>
      <div class="reviews-summary">
        <div class="reviews-rating">4,8</div>
        <div class="reviews-stars">★★★★★</div>
        <div class="reviews-count">Basierend auf Google-Bewertungen</div>
      </div>
    </div>

    <div class="reviews-grid">
      {reviews.map(r => (
        <div class="review-card">
          <div class="review-top">
            <div class="review-avatar" style={`background:${r.color}22;color:${r.color}`}>{r.initial}</div>
            <div class="review-meta">
              <div class="review-name">{r.name}</div>
              <div class="review-time">{r.time}</div>
            </div>
            {r.badge && <span class="review-badge">{r.badge}</span>}
          </div>
          <div class="review-stars">{"★".repeat(r.stars)}{"☆".repeat(5 - r.stars)}</div>
          <p class="review-body">{r.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
