---
import { Image } from 'astro:assets'
import logo from '../assets/images/vai-pizza-logo.png'
const base = Astro.url.pathname === '/' ? '' : '/'
---
<nav class="nav">
  <div class="nav-inner">
    <a href={`${base}#home`} class="nav-logo" aria-label="Vai Pizza">
      <Image src={logo} alt="Vai Pizza Rodizio" width={340} height={192} format="webp" quality={60} loading="eager" />
    </a>
    <div class="nav-links">
      <a href={`${base}#rodizio`}>Rodizio</a>
      <a href={`${base}#preise`}>All you can eat</a>
      <a href="/karte" class="karte-link">Karte</a>
      <a href={`${base}#bar`}>Bar & Cocktails</a>
      <a href={`${base}#besuch`}>Besuch</a>
    </div>
    <div class="nav-actions">
      <span class="nav-phone">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
        </svg>
        0531 / 250 799 44
      </span>
      <a href={`${base}#besuch`} class="btn btn-primary">Tisch reservieren</a>
    </div>
  </div>
</nav>
