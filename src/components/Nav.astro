---
import { Image } from 'astro:assets'
import logo from '../assets/images/vai-pizza-logo.png'
const base = Astro.url.pathname === '/' ? '' : '/'
---
<nav class="nav">
  <div class="nav-inner">
    <a href={`${base}#home`} class="nav-logo" aria-label="Vai Pizza">
      <Image src={logo} alt="Vai Pizza Rodizio" width={99} height={56} densities={[1, 2]} format="webp" quality={60} loading="eager" />
    </a>
    <div class="nav-links">
      <a href={`${base}#rodizio`}>Rodizio</a>
      <a href={`${base}#preise`}>All you can eat</a>
      <a href="/karte" class="karte-link">Karte</a>
      <a href={`${base}#bar`}>Bar & Cocktails</a>
      <a href={`${base}#besuch`}>Besuch</a>
    </div>
    <div class="nav-actions">
      <a href="tel:+4953125079944" class="nav-phone">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
        </svg>
        0531 / 250 799 44
      </a>
      <a href={`${base}#besuch`} class="btn btn-primary nav-reserve">Tisch reservieren</a>
      <button class="nav-toggle" aria-label="Menü öffnen" aria-expanded="false" aria-controls="navMobile">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="nav-mobile" id="navMobile">
    <a href={`${base}#rodizio`}>Rodizio</a>
    <a href={`${base}#preise`}>All you can eat</a>
    <a href="/karte">Karte</a>
    <a href={`${base}#bar`}>Bar & Cocktails</a>
    <a href={`${base}#besuch`}>Besuch</a>
    <a href={`${base}#besuch`} class="btn btn-primary nav-mobile-cta">Tisch reservieren</a>
  </div>
</nav>

<script>
  const toggle = document.querySelector('.nav-toggle')
  const menu = document.getElementById('navMobile')
  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      menu.classList.toggle('open', open)
      toggle.classList.toggle('is-open', open)
      toggle.setAttribute('aria-expanded', String(open))
      toggle.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen')
      document.body.classList.toggle('nav-open', open)
    }
    toggle.addEventListener('click', () => setOpen(!menu.classList.contains('open')))
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => setOpen(false)))
  }
</script>
