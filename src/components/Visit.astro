        <table class="hours-table">
          <tbody>
            <tr><td>Montag</td><td>17:00 – 23:00</td></tr>
            <tr><td>Dienstag</td><td>17:00 – 23:00</td></tr>
            <tr><td>Mittwoch</td><td>17:00 – 23:00</td></tr>
