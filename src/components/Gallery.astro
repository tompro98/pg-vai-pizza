---
import { Image } from 'astro:assets'
import aussenbereich from '../assets/images/vai-pizza-aussenbereich.jpg'
import bar from '../assets/images/vai-pizza-bar.jpg'
import cocktailFrucht from '../assets/images/vai-pizza-cocktail-frucht.jpg'
import barBereich from '../assets/images/vai-pizza-bar-bereich.jpg'
import barkeeperBlue from '../assets/images/vai-pizza-barkeeper-blue.jpg'
import innenbereich from '../assets/images/vai-pizza-innenbereich.jpg'
---
<section id="galerie" class="gallery">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow tomato">Bei uns</span>
        <h2 class="display italic">Wie ein Abend bei Vai aussieht.</h2>
      </div>
      <p>Voller Tische, leise Glasklänge, der Duft von Steinofen­pizza, draußen Paulaner-Schirme im Sommer.</p>
    </div>

    <div class="gallery-grid">
      <div class="g-item large">
        <Image src={aussenbereich} alt="Außenbereich" format="webp" loading="lazy" />
        <span class="tag">Außenbereich</span>
      </div>
      <div class="g-item tall">
        <Image src={bar} alt="Bar" format="webp" loading="lazy" />
        <span class="tag">Bar</span>
      </div>
      <div class="g-item med">
        <Image src={cocktailFrucht} alt="Cocktail" format="webp" loading="lazy" />
      </div>
      <div class="g-item med text">
        <span class="sub">Seit 2014</span>
        <span class="big">Brasilien trifft<br/>Italien</span>
      </div>
      <div class="g-item wide">
        <Image src={barBereich} alt="Bar Bereich" format="webp" loading="lazy" />
        <span class="tag">Innenbereich</span>
      </div>
      <div class="g-item med">
        <Image src={barkeeperBlue} alt="Barkeeper" format="webp" loading="lazy" />
      </div>
      <div class="g-item med">
        <Image src={innenbereich} alt="Restaurant" format="webp" loading="lazy" />
      </div>
    </div>
  </div>
</section>
