---
---
<section id="galerie" class="gallery">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow tomato">Bei uns</span>
        <h2 class="display italic">Wie ein Abend bei Vai aussieht.</h2>
      </div>
      <p>Voller Tische, leise Glasklänge, der Duft von Steinofen­pizza, draußen Paulaner-Schirme im Sommer.</p>
    </div>

    <div class="gallery-grid">
      <div class="g-item large">
        <img src="/images/vai-pizza-aussenbereich.jpg" alt="Außenbereich" loading="lazy" />
        <span class="tag">Außenbereich</span>
      </div>
      <div class="g-item tall">
        <img src="/images/vai-pizza-bar.jpg" alt="Bar" loading="lazy" />
        <span class="tag">Bar</span>
      </div>
      <div class="g-item med">
        <img src="/images/vai-pizza-cocktail-frucht.jpg" alt="Cocktail" loading="lazy" />
      </div>
      <div class="g-item med text">
        <span class="sub">Seit 2014</span>
        <span class="big">Brasilien trifft<br/>Italien</span>
      </div>
      <div class="g-item wide">
        <img src="/images/vai-pizza-bar-bereich.jpg" alt="Bar Bereich" loading="lazy" />
        <span class="tag">Innenbereich</span>
      </div>
      <div class="g-item med">
        <img src="/images/vai-pizza-barkeeper-blue.jpg" alt="Barkeeper" loading="lazy" />
      </div>
      <div class="g-item med">
        <img src="/images/vai-pizza-innenbereich.jpg" alt="Restaurant" loading="lazy" />
      </div>
    </div>
  </div>
</section>
